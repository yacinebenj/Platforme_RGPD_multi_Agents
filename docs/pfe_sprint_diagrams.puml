  usecase "Consulter le tableau\nde bord global" as UC_S4_3
  usecase "Suivre les traces\net historiques" as UC_S4_4
  usecase "Consulter l'etat\nd'execution" as UC_S4_5
  usecase "Relancer une analyse\nciblee" as UC_S4_6
